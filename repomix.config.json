{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "context/ipxdata-frontend-repomix.xml",
    "style": "xml",
    "parsableStyle": true,
    "removeComments": false,
    "removeEmptyLines": true,
    "showLineNumbers": true,
    "topFilesLength": 20,
    "includeFullDirectoryStructure": true,
    "git": {
      "sortByChanges": true,
      "includeDiffs": false,
      "includeLogs": false
    }
  },
  "include": [
    "app/**/*",
    "components/**/*",
    "lib/**/*",
    "scripts/**/*",
    "tools/**/*",
    "docs/**/*",
    "*.md",
    "*.json",
    "*.ts",
    "*.tsx",
    "*.js",
    "*.mjs"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".next/**",
      "node_modules/**",
      "release/**",
      "context/**",
      "frontend/**",
      "public/brands/**",
      "*.log",
      "*.zip",
      "tsconfig.tsbuildinfo",
      ".env*"
    ]
  }
}
