# Por padrao, o proxy usa o hostname aberto no navegador.
# Exemplo: frontend em http://10.0.0.20:3000 -> API em http://10.0.0.20:8080.
IPXDATA_API_URL=
IPXDATA_API_PROTOCOL=http
IPXDATA_API_PORT=8080

# Defina IPXDATA_API_URL apenas quando a API estiver em outro host.
# IPXDATA_API_URL=https://api.exemplo.com

# Normalmente deixe em branco ou mantenha /api/v1 para usar o proxy do Next.
# Use uma URL absoluta apenas se o backend estiver com CORS liberado para o frontend.
NEXT_PUBLIC_IPXDATA_API_BASE_URL=/api/v1

# Ano inicial consultado pela matriz anual dos Relatorios.
# Mantenha estavel para acrescentar novos anos sem remover o historico antigo.
NEXT_PUBLIC_REPORT_HISTORY_START_YEAR=2020

# Usado pelos scripts de inicializacao deste projeto.
IPXDATA_FRONTEND_HOST=0.0.0.0
IPXDATA_FRONTEND_PORT=3000

# Opcional: marcas customizadas para a tela de login.
# A chave e resolvida por URL (?empresa=cliente-a) ou subdominio (cliente-a.seudominio.com).
# Coloque os logos em public/brands/<chave>/logo.png antes do build.
# NEXT_PUBLIC_IPXDATA_LOGIN_BRANDS=[{"key":"cliente-a","companyName":"Cliente A","logoUrl":"/brands/cliente-a/logo.png","accentColor":"#0B4EA2","subtitle":"IPXData"}]
