{
  "name": "ipxdata-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:analytics": "node --test tests/analytics-time.test.mjs",
    "check:production": "npm run typecheck && npm run build",
    "context:skeleton": "node tools/generate-code-skeleton.mjs",
    "context:pack": "repomix --config repomix.config.json",
    "context:pack:compressed": "repomix --config repomix.config.json --compress -o context/ipxdata-frontend-compressed.xml",
    "context:all": "npm run context:skeleton && npm run context:pack"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "echarts": "6.1.0",
    "exceljs": "4.4.0",
    "gsap": "3.15.0",
    "jspdf": "4.2.1",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.10",
    "repomix": "1.16.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  }
}
